# ---- LLM (agnostico via init_chat_model) ----
# provider: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.2

# Claves segun el provider que uses:
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Base de datos (PostgreSQL, unica tecnologia de persistencia — Fase 6) ----
# DSN de SQLAlchemy para la BD de negocio (users/projects/blueprints/experiments):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/blueprint
# DSN sincrono que usa el checkpointer de LangGraph (sin el +psycopg de SQLAlchemy);
# el search_path aisla las tablas del checkpointer en el esquema `langgraph`:
LANGGRAPH_PG_DSN=postgresql://postgres:postgres@localhost:5432/blueprint?options=-c%20search_path%3Dlanggraph

# Pool de conexiones SQLAlchemy (Fase 2). Cubre solo CRUD de negocio y la
# escritura de la proyeccion derivada `blueprints.state`: el checkpointer de
# LangGraph usa su propia conexion unica y no consume este pool.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Fase 2 — activa la validacion temporal (shadow read) entre `blueprints.state`
# y el checkpointer al final de cada ejecucion/resume. Solo para el periodo de
# validacion; dejar en false una vez confirmada la consistencia.
SHADOW_READ_ENABLED=false

# ---- Fase 3 — contrato del futuro Knowledge Service (RAG, aun sin backend) ----
# No activan ninguna ruta de codigo en esta fase: `semantic_search` es unicamente
# un Protocol sin implementacion (app/catalog/service.py). Sin variable de
# dimension de vector: depende del proveedor de embeddings, aun no seleccionado
# (se define en la Fase 4).
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0

# ---- Investigador (Tavily) — solo configuracion, aun sin activar ninguna
# ruta de codigo nueva (ver docs/plan-agente-investigador-tavily.md) ----
TAVILY_API_KEY=tvly-...
RESEARCH_ENABLED=true

# ---- Auth ----
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- App ----
CORS_ORIGINS=http://localhost:3000

# ---- Observabilidad (LangSmith) ----
# Activa el tracing solo si LANGSMITH_TRACING=true Y hay API key (ver
# app/core/observability.py:tracing_enabled). Los agentes no se tocan: la
# metadata se inyecta via RunnableConfig al invocar el grafo.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=validation-blueprint-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Privacidad: oculta prompts/respuestas en LangSmith (no afecta al tracing local):
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
